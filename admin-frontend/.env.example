# 前端环境变量示例（已纳入版本控制，仅作配置说明，不含真实值）
#
# 部署时：复制本文件为 .env.local（已被 .gitignore 忽略，不会入库），并填入真实值后重新构建：
#   cp .env.example .env.local
#   npm run build
#
# 说明：
# - 备案号/联系邮箱原本硬编码在前端源码中，现统一改为从环境变量读取，
#   源码不再包含任何真实主体信息，便于公开仓库与后续线上修 bug 时免改源码。
# - 变量必须以 VITE_ 开头才会暴露给前端（Vite 构建时内联进产物）。
# - 若某变量留空，对应内容在前端不渲染（公开仓库默认即如此）。

# ICP 备案号（工信部备案，如 蜀ICP备2026034112号-1）
VITE_BEIAN_ICP=

# 公安联网备案号（如 川公网安备51052402000130号），需配合 public/gongan-badge.png 徽标
VITE_BEIAN_MPS=

# 联系邮箱（展示在「联系我们」页）
VITE_CONTACT_EMAIL=

# 后端接口基础路径（开发默认 /api，由 Vite 代理转发；生产按需填写域名）
VITE_API_BASE_URL=/api
