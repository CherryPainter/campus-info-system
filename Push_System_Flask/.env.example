# ========== 应用配置 ==========
APP_NAME=校园信息聚合与智能推送系统
APP_VERSION=6.11.2
DEBUG=false
HOST=0.0.0.0
PORT=29528

# ========== 数据库配置 (MySQL) ==========
# 重要：运行时代码仅支持 MySQL，不读取 DATABASE_URL；
# 以下为 config.py 实际读取的变量（默认值见右，生产务必改为真实库）
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=123456
DATABASE_NAME=push_system

# ========== 安全配置 ==========
# 必填（生产）：固定强随机密钥，重启不变；否则重启即全员下线且多实例密钥不一致
# 生成：python -c "import secrets;print(secrets.token_hex(48))"
SECRET_KEY=your-secret-key-here-change-in-production
ADMIN_TOKEN=your-admin-token-here
AUTH_ENABLED=true
# 是否强制管理员启用 MFA（默认 true；设为 false 可关闭，便于特殊场景）
FORCE_ADMIN_MFA=true

# ========== JWT 认证配置 ==========
# JWT 管理后台登录用户名（默认 admin）
JWT_ADMIN_USERNAME=admin
# JWT 管理后台登录密码（为空则使用 ADMIN_TOKEN 作为初始密码）
JWT_ADMIN_PASSWORD=
# Access Token 有效期（秒），默认 3600（1小时）
JWT_ACCESS_TOKEN_EXPIRE=3600
# Refresh Token 有效期（秒），默认 604800（7天）
JWT_REFRESH_TOKEN_EXPIRE=604800

# ========== CORS 配置 ==========
# 允许跨域的域名，逗号分隔（生产务必改为真实前端域名，勿写死 localhost）
ALLOWED_ORIGINS=http://localhost:29528,http://localhost:5173

# ========== Redis 配置 (限流/会话共享) ==========
# 留空则 Flask-Limiter 退回内存存储（多 worker / 重启限流失效）
# 生产建议填写，例如 redis://:密码@127.0.0.1:6379/0
REDIS_URL=

# ========== Python路径配置 ==========
# 爬虫子进程使用的 Python 解释器路径
# 本地开发: python 或 python3
# 服务器部署: ../venv/bin/python3 (venv 与 Push_System_Flask 同级)
PYTHON_PATH=python

# ========== 教务系统 ==========
JWXT_USERNAME=your-username
JWXT_PASSWORD=your-password
JWXT_HEADLESS=true
JWXT_TIMEOUT=180
JWXT_SAVE_LOG=true
JWXT_CAPTCHA_MODE=auto

# ========== 企业微信 ==========
# 支持多个 webhook 地址，用逗号分隔
# 示例（单个）: WECOM_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
# 示例（多个）: WECOM_WEBHOOK=https://...key=xxx,https://...key=yyy
WECOM_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-key

# 状态告警 webhook（可选，支持多地址）
WECOM_STATUS_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-status-key

# ========== 班级配置 ==========
CLASS_NAME=ZK2401

# ========== 定时任务 ==========
CRON_EXPRESSION=0 7,13 * * *

# ========== 推送规则 ==========
DAILY_PUSH_TIME=07:00
BEFORE_CLASS_MINUTES=15
BEFORE_END_CLASS_MINUTES=10

# ========== 爬虫配置 ==========
# 爬虫是否使用无头模式（true=无头/false=有界面调试）
SPIDER_HEADLESS=true

# ========== Tesseract OCR ==========
# Windows 示例: C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux 示例:  /usr/bin/tesseract
# 留空则自动推断 (要求 tesseract 在 PATH 中)
TESSERACT_CMD=

# ========== 电量监控模块 ==========
# 必填：宿舍电表系统 Cookie
# 获取方式：在微信内打开 http://dk.cqie.cn，F12 复制 Cookie
# 格式示例：JSESSIONID=xxx; leech_k=xxx
ELECTRICITY_CRAWLER_COOKIE=

# 可选：电表系统基础 URL（默认 http://dk.cqie.cn）
ELECTRICITY_CRAWLER_BASE_URL=http://dk.cqie.cn

# 可选：每次爬取最大页数，建议 2（默认 2）
ELECTRICITY_CRAWLER_MAX_PAGES=2

# 可选：低电量告警阈值（度），默认 10.0
ELECTRICITY_LOW_POWER_THRESHOLD=10.0

# 可选：低电量告警最小间隔（小时），默认 4.0
ELECTRICITY_LOW_POWER_INTERVAL_HOURS=4.0

# 可选：每日报告推送时间（HH:MM），默认 00:30
ELECTRICITY_SCHEDULE_DAILY=00:30

# 可选：每周报告推送时间（HH:MM），默认 00:30
ELECTRICITY_SCHEDULE_WEEKLY=00:30

# 可选：每周报告推送星期（cron 格式，如 mon），默认 mon
ELECTRICITY_SCHEDULE_WEEKLY_DAY=mon

# 可选：每月报告推送时间（HH:MM），默认 00:30
ELECTRICITY_SCHEDULE_MONTHLY=00:30

# 可选：每月报告推送日（1~28），默认 1
ELECTRICITY_SCHEDULE_MONTHLY_DAY=1

# 可选：Cookie 有效性检测时间（HH:MM），默认 20:00
ELECTRICITY_COOKIE_CHECK_TIME=20:00

# ========== 天气模块 ==========
# 必填：和风天气 API Key（JWT Token）
# 获取方式：https://dev.qweather.com/ 创建项目
QWEATHER_API_KEY=

# 可选：JWT 鉴权方式（推荐，需配合私钥文件 ed25519-private.pem）
# CREDENTIAL_ID / PROJECT_ID 在和风天气控制台获取；PRIVATE_KEY_PATH 指向 Ed25519 私钥
QWEATHER_CREDENTIAL_ID=
QWEATHER_PROJECT_ID=
QWEATHER_PRIVATE_KEY_PATH=ed25519-private.pem

# 可选：城市 LocationID（默认 101040100 重庆）
QWEATHER_LOCATION=101040100

# 可选：API 请求域名（默认开发版 https://devapi.qweather.com）
# 付费版请改为 https://api.qweather.com
QWEATHER_API_HOST=https://devapi.qweather.com

# 可选：预警 API 所需纬度（默认重庆 29.56）
QWEATHER_LATITUDE=29.56

# 可选：预警 API 所需经度（默认重庆 106.55）
QWEATHER_LONGITUDE=106.55

# 可选：每日晨报推送时间（HH:MM），默认 07:00
QWEATHER_SCHEDULE_DAILY=07:00
